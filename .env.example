POSTGRES_DB=football_db
POSTGRES_USER=football_user
POSTGRES_PASSWORD=football_password
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://football_user:football_password@localhost:5432/football_db
BACKUP_DIR=backups
BACKUP_FILE_TEMPLATE=football_backup_%Y%m%d_%H%M%S.sql

PREDICTION_FOOTBALL_AUTH_SECRET=change-this-local-secret
PREDICTION_FOOTBALL_TOKEN_MINUTES=1440

API_FOOTBALL_API_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_TIMEOUT_SECONDS=20
API_FOOTBALL_SEASON=2026
API_FOOTBALL_SCHEDULER_ENABLED=true
API_FOOTBALL_SCHEDULER_TIMEZONE=Europe/Moscow
API_FOOTBALL_FIXTURES_SYNC_TIME=03:00
API_FOOTBALL_ODDS_SYNC_TIME=06:00
API_FOOTBALL_RESULTS_SYNC_TIME=23:30
API_FOOTBALL_FIXTURES_DAYS_AHEAD=14
API_FOOTBALL_ODDS_DAYS_AHEAD=7
API_FOOTBALL_RESULTS_LOOKBACK_DAYS=2
API_FOOTBALL_MAX_SYNC_FIXTURES=25
